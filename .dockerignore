# Version control
.git/
.gitattributes
.gitignore

# Node / frontend build artefacts (package-lock.json kept — needed for `npm ci`
# in the frontend build stage).
node_modules/
npm-debug.log
yarn-error.log
yarn.lock

# Composer deps (rebuilt inside the image)
vendor/

# Environment files — injected at runtime, never baked in
.env
.env.*
!.env.example

# Storage runtime dirs (keep the skeleton dirs, drop runtime data)
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*

# Tests — not needed in production
tests/
phpunit.xml
phpstan.neon
pest.php

# Documentation
*.md
PLAN.md
README.md

# CI / tooling (tsconfig/vite.config/components/biome are needed by the
# frontend build stage, so keep them in the context).
.github/
.editorconfig
.npmrc

# Docker artefacts themselves (avoid recursive COPY confusion)
Dockerfile
docker-compose.yml
.dockerignore
