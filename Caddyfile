{
	frankenphp

	order php_server before file_server
	order php before file_server

	admin off
	auto_https off
}

:{$PORT:8000} {
	root * /app/public
	encode gzip zstd

	# file_server serves static files directly; otherwise hand off to PHP worker.
	@static {
		file
		not path /index.php
	}
	handle @static {
		file_server
	}

	php_server
}
