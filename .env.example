APP_NAME="Culinary Bot API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# In containers/production use `stderr` so logs reach the platform (Railway, etc.).
# Local dev can use `single` to tail storage/logs/laravel.log.
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=culinary_bot
DB_USERNAME=postgres
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# Restaurant provider driver:
#   zomato   - HTTP calls to ZOMATO_BASE_URL (production default).
#              In prod this points at our own in-app stub
#              (/zomato/api/v2.1/*) since the public Zomato API is shut down.
#   fixture  - Reads fixture JSON directly, no HTTP. Used in the test suite.
RESTAURANT_PROVIDER=zomato
ZOMATO_BASE_URL=http://localhost:8000/zomato/api/v2.1
ZOMATO_USER_KEY=stub

# Telegram: obtain a bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://your-domain.example/api/telegram/webhook
TELEGRAM_BOT_API_BASE=https://api.telegram.org

# Generate: openssl rand -hex 64
JWT_CHALLENGE_SECRET=
JWT_CHALLENGE_TTL_MINUTES=5

SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=password

LOG_REDACT_KEYS=password,password_confirmation,current_password,token,secret,authorization,cookie,two_factor_secret,challenge_token,access_token,refresh_token
API_LOG_RETENTION_DAYS=30

POSTMAN_API_KEY=
