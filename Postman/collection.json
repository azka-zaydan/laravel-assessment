    {
      "name": "2FA - Enable",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{user_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"password\":\"{{test_password}}\"}" },
        "url": { "raw": "{{base_url}}/api/2fa/enable", "host": ["{{base_url}}"], "path": ["api", "2fa", "enable"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 or 403', () => pm.expect([200, 403]).to.include(pm.response.code));",
              "if (pm.response.code === 200) pm.test('otpauth_url returned', () => pm.expect(pm.response.json().otpauth_url).to.match(/^otpauth:\\/\\//));"
            ]
          }
        }
      ]
    },
    {
      "name": "2FA - Confirm",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{user_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"code\":\"123456\"}" },
        "description": "Replace code with a real 6-digit TOTP from the otpauth_url.",
        "url": { "raw": "{{base_url}}/api/2fa/confirm", "host": ["{{base_url}}"], "path": ["api", "2fa", "confirm"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 or 422', () => pm.expect([200, 422]).to.include(pm.response.code));",
              "if (pm.response.code === 200) pm.expect(pm.response.json().recovery_codes).to.have.lengthOf(8);"
            ]
          }
        }
      ]
    },
