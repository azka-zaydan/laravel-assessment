    {
      "name": "Telegram - Webhook (simulated)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Telegram-Bot-Api-Secret-Token", "value": "{{telegram_webhook_secret}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"update_id\":123,\"message\":{\"message_id\":1,\"from\":{\"id\":42,\"is_bot\":false,\"first_name\":\"Tester\"},\"chat\":{\"id\":42,\"type\":\"private\"},\"date\":1713734400,\"text\":\"/start\"}}" },
        "url": { "raw": "{{base_url}}/api/telegram/webhook", "host": ["{{base_url}}"], "path": ["api", "telegram", "webhook"] }
